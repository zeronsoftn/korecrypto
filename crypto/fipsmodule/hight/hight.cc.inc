// HIGHT block cipher (KS X 1213-2), a 64-bit-block, 128-bit-key cipher and
// KCMVP validation-target algorithm. The Delta/F0/F1 tables and the round
// logic are ported from the KISA reference implementation. Byte-oriented, so
// there are no endianness concerns. Verified against the KISA reference / TTA
// test vector.

#include <openssl/hight.h>

