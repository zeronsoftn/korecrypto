extern "C" {

int ARIA_set_encrypt_key(const uint8_t *key, unsigned bits, ARIA_KEY *aria_key) {
  unsigned rounds = rounds_for_bits(bits);
  if (rounds == 0) {
    return -1;
  }
  expand_round_keys(aria_key->rk, key, bits, rounds);
  aria_key->rounds = rounds;
  return 0;
}

int ARIA_set_decrypt_key(const uint8_t *key, unsigned bits, ARIA_KEY *aria_key) {
  unsigned rounds = rounds_for_bits(bits);
  if (rounds == 0) {
    return -1;
  }

  ARIA_KEY enc;
  expand_round_keys(enc.rk, key, bits, rounds);

  // Decryption round keys: dk1 = ek{n+1}, dk{n+1} = ek1, and
  // dk{i} = A(ek{n+2-i}) for the interior keys.
  const unsigned n = rounds;
  memcpy(aria_key->rk[0], enc.rk[n], 16);
  for (unsigned i = 1; i < n; i++) {
    diffusion(aria_key->rk[i], enc.rk[n - i]);
  }
  memcpy(aria_key->rk[n], enc.rk[0], 16);
  aria_key->rounds = rounds;

  OPENSSL_cleanse(&enc, sizeof(enc));
  return 0;
}

void ARIA_encrypt_block(const uint8_t in[ARIA_BLOCK_SIZE],
                        uint8_t out[ARIA_BLOCK_SIZE], const ARIA_KEY *key) {
  const unsigned n = key->rounds;
  uint8_t s[16];
  memcpy(s, in, 16);

  // Rounds 1..n-1 alternate the odd (FO) and even (FE) round functions.
  for (unsigned r = 0; r + 1 < n; r++) {
    if ((r & 1) == 0) {
      fo(s, s, key->rk[r]);
    } else {
      fe(s, s, key->rk[r]);
    }
  }

  // Final round n: SL2(s ^ ek{n}) ^ ek{n+1}.
  xor16(s, s, key->rk[n - 1]);
  sl2(s);
  xor16(out, s, key->rk[n]);

  OPENSSL_cleanse(s, sizeof(s));
}

}  // extern "C"
