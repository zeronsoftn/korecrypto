inline void xor16(uint8_t out[16], const uint8_t a[16], const uint8_t b[16]) {
  for (int i = 0; i < 16; i++) {
    out[i] = a[i] ^ b[i];
  }
}

// Substitution layer SL1 (type 1): SB1, SB2, SB3, SB4 repeating.
void sl1(uint8_t s[16]) {
  for (int i = 0; i < 16; i += 4) {
    s[i + 0] = kSB1[s[i + 0]];
    s[i + 1] = kSB2[s[i + 1]];
    s[i + 2] = kSB3[s[i + 2]];
    s[i + 3] = kSB4[s[i + 3]];
  }
}

// Substitution layer SL2 (type 2): SB3, SB4, SB1, SB2 repeating.
void sl2(uint8_t s[16]) {
  for (int i = 0; i < 16; i += 4) {
    s[i + 0] = kSB3[s[i + 0]];
    s[i + 1] = kSB4[s[i + 1]];
    s[i + 2] = kSB1[s[i + 2]];
    s[i + 3] = kSB2[s[i + 3]];
  }
}

// Diffusion layer A (RFC 5794, Section 2.4.3). A is an involution.
void diffusion(uint8_t y[16], const uint8_t x[16]) {
  y[0] = x[3] ^ x[4] ^ x[6] ^ x[8] ^ x[9] ^ x[13] ^ x[14];
  y[1] = x[2] ^ x[5] ^ x[7] ^ x[8] ^ x[9] ^ x[12] ^ x[15];
  y[2] = x[1] ^ x[4] ^ x[6] ^ x[10] ^ x[11] ^ x[12] ^ x[15];
  y[3] = x[0] ^ x[5] ^ x[7] ^ x[10] ^ x[11] ^ x[13] ^ x[14];
  y[4] = x[0] ^ x[2] ^ x[5] ^ x[8] ^ x[11] ^ x[14] ^ x[15];
  y[5] = x[1] ^ x[3] ^ x[4] ^ x[9] ^ x[10] ^ x[14] ^ x[15];
  y[6] = x[0] ^ x[2] ^ x[7] ^ x[9] ^ x[10] ^ x[12] ^ x[13];
  y[7] = x[1] ^ x[3] ^ x[6] ^ x[8] ^ x[11] ^ x[12] ^ x[13];
  y[8] = x[0] ^ x[1] ^ x[4] ^ x[7] ^ x[10] ^ x[13] ^ x[15];
  y[9] = x[0] ^ x[1] ^ x[5] ^ x[6] ^ x[11] ^ x[12] ^ x[14];
  y[10] = x[2] ^ x[3] ^ x[5] ^ x[6] ^ x[8] ^ x[13] ^ x[15];
  y[11] = x[2] ^ x[3] ^ x[4] ^ x[7] ^ x[9] ^ x[12] ^ x[14];
  y[12] = x[1] ^ x[2] ^ x[6] ^ x[7] ^ x[9] ^ x[11] ^ x[12];
  y[13] = x[0] ^ x[3] ^ x[6] ^ x[7] ^ x[8] ^ x[10] ^ x[13];
  y[14] = x[0] ^ x[3] ^ x[4] ^ x[5] ^ x[9] ^ x[11] ^ x[14];
  y[15] = x[1] ^ x[2] ^ x[4] ^ x[5] ^ x[8] ^ x[10] ^ x[15];
}

// FO(D, RK) = A(SL1(D ^ RK)); result written to |out| (may alias |d|).
void fo(uint8_t out[16], const uint8_t d[16], const uint8_t rk[16]) {
  uint8_t t[16];
  xor16(t, d, rk);
  sl1(t);
  diffusion(out, t);
}

// FE(D, RK) = A(SL2(D ^ RK)); result written to |out| (may alias |d|).
void fe(uint8_t out[16], const uint8_t d[16], const uint8_t rk[16]) {
  uint8_t t[16];
  xor16(t, d, rk);
  sl2(t);
  diffusion(out, t);
}

// rotr128 rotates the 128-bit big-endian value |in| right by |bits| and writes
// the result to |out| (must not alias |in|).
void rotr128(uint8_t out[16], const uint8_t in[16], unsigned bits) {
  bits &= 127;
  const unsigned nbytes = bits >> 3, nbits = bits & 7;
  uint8_t t[16];
  for (unsigned i = 0; i < 16; i++) {
    t[i] = in[(i + 16 - nbytes) % 16];
  }
  if (nbits == 0) {
    memcpy(out, t, 16);
    return;
  }
  for (unsigned i = 0; i < 16; i++) {
    out[i] = (uint8_t)((t[i] >> nbits) | (t[(i + 16 - 1) % 16] << (8 - nbits)));
  }
}

inline void rotl128(uint8_t out[16], const uint8_t in[16], unsigned bits) {
  rotr128(out, in, 128 - (bits & 127));
}

// expand_round_keys computes the encryption round keys ek1..ek{rounds+1} from
// the master key and stores them in |rk[0..rounds]|.
void expand_round_keys(uint8_t rk[ARIA_MAXNR + 1][16], const uint8_t *key,
                       unsigned bits, unsigned rounds) {
  const uint8_t *ck1, *ck2, *ck3;
  switch (bits) {
    case 128:
      ck1 = kC1;
      ck2 = kC2;
      ck3 = kC3;
      break;
    case 192:
      ck1 = kC2;
      ck2 = kC3;
      ck3 = kC1;
      break;
    default:  // 256
      ck1 = kC3;
      ck2 = kC1;
      ck3 = kC2;
      break;
  }

  uint8_t kl[16], kr[16] = {0};
  memcpy(kl, key, 16);
  memcpy(kr, key + 16, (bits - 128) / 8);

  uint8_t w0[16], w1[16], w2[16], w3[16], t[16];
  memcpy(w0, kl, 16);
  fo(t, w0, ck1);
  xor16(w1, t, kr);
  fe(t, w1, ck2);
  xor16(w2, t, w0);
  fo(t, w2, ck3);
  xor16(w3, t, w1);

  uint8_t r[16];
  // ek1..ek4 use >>> 19.
  rotr128(r, w1, 19);
  xor16(rk[0], w0, r);
  rotr128(r, w2, 19);
  xor16(rk[1], w1, r);
  rotr128(r, w3, 19);
  xor16(rk[2], w2, r);
  rotr128(r, w0, 19);
  xor16(rk[3], r, w3);
  // ek5..ek8 use >>> 31.
  rotr128(r, w1, 31);
  xor16(rk[4], w0, r);
  rotr128(r, w2, 31);
  xor16(rk[5], w1, r);
  rotr128(r, w3, 31);
  xor16(rk[6], w2, r);
  rotr128(r, w0, 31);
  xor16(rk[7], r, w3);
  // ek9..ek12 use <<< 61.
  rotl128(r, w1, 61);
  xor16(rk[8], w0, r);
  rotl128(r, w2, 61);
  xor16(rk[9], w1, r);
  rotl128(r, w3, 61);
  xor16(rk[10], w2, r);
  rotl128(r, w0, 61);
  xor16(rk[11], r, w3);
  // ek13..ek16 use <<< 31.
  rotl128(r, w1, 31);
  xor16(rk[12], w0, r);
  rotl128(r, w2, 31);
  xor16(rk[13], w1, r);
  rotl128(r, w3, 31);
  xor16(rk[14], w2, r);
  rotl128(r, w0, 31);
  xor16(rk[15], r, w3);
  // ek17 uses <<< 19.
  rotl128(r, w1, 19);
  xor16(rk[16], w0, r);

  OPENSSL_cleanse(kl, sizeof(kl));
  OPENSSL_cleanse(kr, sizeof(kr));
  OPENSSL_cleanse(w0, sizeof(w0));
  OPENSSL_cleanse(w1, sizeof(w1));
  OPENSSL_cleanse(w2, sizeof(w2));
  OPENSSL_cleanse(w3, sizeof(w3));
  OPENSSL_cleanse(t, sizeof(t));
  OPENSSL_cleanse(r, sizeof(r));
  (void)rounds;
}

unsigned rounds_for_bits(unsigned bits) {
  switch (bits) {
    case 128:
      return 12;
    case 192:
      return 14;
    case 256:
      return 16;
    default:
      return 0;
  }
}

